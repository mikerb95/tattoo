generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Artist {
  id         String   @id @default(cuid())
  email      String   @unique
  password   String
  name       String
  specialty  String
  initials   String
  color      String   @default("#C9A864")
  status     String   @default("online") // online, session, offline
  role       String   @default("artist") // artist, admin
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  appointments Appointment[]
  healingCases HealingCase[]
  designs      Design[]
}

model Client {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  age       Int?
  allergies String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments Appointment[]
  consentForms ConsentForm[]
  healingCases HealingCase[]
  designs      Design[]
}

model Appointment {
  id          String   @id @default(cuid())
  clientId    String
  artistId    String
  date        DateTime
  duration    Float    // hours
  piece       String
  zone        String
  status      String   @default("pending")
  // pending | confirmed | in-progress | completed | cancelled | rescheduled
  totalAmount Float?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client      Client       @relation(fields: [clientId], references: [id])
  artist      Artist       @relation(fields: [artistId], references: [id])
  deposit     Deposit?
  consentForm ConsentForm?
}

model Deposit {
  id            String    @id @default(cuid())
  appointmentId String    @unique
  clientId      String
  amount        Float
  dueDate       DateTime
  paidAt        DateTime?
  status        String    @default("pending")
  // pending | paid | refunded | cancelled
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

model ConsentForm {
  id              String    @id @default(cuid())
  appointmentId   String    @unique
  clientId        String
  folio           String    @unique
  status          String    @default("draft")
  // draft | sent | opened | signed | archived
  clientSignedAt  DateTime?
  artistSignedAt  DateTime?
  clientSignature String?
  artistSignature String?
  sentAt          DateTime?
  openedAt        DateTime?
  // JSON checklist: { idVerified, medicalQuestionnaire, depositReceived, sketchApproved, postSessionPhoto }
  checklist       String    @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  client      Client      @relation(fields: [clientId], references: [id])
}

model Design {
  id        String   @id @default(cuid())
  clientId  String
  artistId  String?
  title     String
  zone      String
  style     String?
  date      DateTime
  imageUrl  String?
  tags      String   @default("[]")
  createdAt DateTime @default(now())

  client Client  @relation(fields: [clientId], references: [id])
  artist Artist? @relation(fields: [artistId], references: [id])
}

model HealingCase {
  id        String   @id @default(cuid())
  clientId  String
  artistId  String
  piece     String
  zone      String
  startDate DateTime @default(now())
  status    String   @default("active")
  // active | completed | concern | discharged
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client  Client       @relation(fields: [clientId], references: [id])
  artist  Artist       @relation(fields: [artistId], references: [id])
  entries HealingEntry[]
}

model HealingEntry {
  id            String   @id @default(cuid())
  healingCaseId String
  day           Int
  // JSON array: ["itching", "swelling", "scabbing", "redness", "fever", "pus"]
  symptoms      String   @default("[]")
  note          String?
  photoUrl      String?
  status        String   // normal | watch | urgent
  createdAt     DateTime @default(now())

  healingCase HealingCase @relation(fields: [healingCaseId], references: [id], onDelete: Cascade)
}

model Portfolio {
  id        String   @id @default(cuid())
  title     String
  artist    String
  style     String
  zone      String?
  year      Int
  imageUrl  String?
  tags      String   @default("[]")
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
}
